# env / secrets — .env can live anywhere; the bare name matches at any depth.
.env
.env.local

# SQLite database — dir kept via .gitkeep, content excluded
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Per-site uploads — dir kept via .gitkeep, user files excluded
site/public/uploads/*
!site/public/uploads/.gitkeep
!site/public/uploads/.htaccess

# Claude Code workflow-mode marker (per-developer / per-session)
.claude-mode
.claude/settings.local.json

# OS / editor
Thumbs.db
.DS_Store
desktop.ini
.idea/
.vscode/
*.swp
*~

# Vendor (if Composer ever shows up — it shouldn't)
vendor/

# Logs
*.log

# Tailwind CLI standalone binary — downloaded on demand by
# core/build/build-css.sh, ~40MB, platform-specific. The compiled
# output (site/public/assets/css/styles.css) IS committed.
/bin/tailwindcss
