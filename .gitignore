# env / secrets — .env can live at any depth (root in old layout,
# public_html/ in current layout); the bare name matches anywhere.
.env
.env.local

# SQLite database — dir kept via .gitkeep, content excluded
public_html/data/*.db
public_html/data/*.db-journal
public_html/data/*.db-wal
public_html/data/*.db-shm

# Uploads — dir kept via .gitkeep, user files excluded
public_html/uploads/*
!public_html/uploads/.gitkeep
!public_html/uploads/.htaccess

# OS / editor
Thumbs.db
.DS_Store
desktop.ini
.idea/
.vscode/
*.swp
*~

# Vendor (if Composer ever shows up — it shouldn't)
vendor/

# Logs
*.log
