# Phase 1 .htaccess — minimal. Full security headers + clean URL rewrites
# arrive in Phase 2 once we have actual routes.

# Default doc
DirectoryIndex index.php

# Force HTTPS in production only (skip on localhost so XAMPP dev works on http)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Block access to sensitive files if they ever land in the webroot
<FilesMatch "^\.env|\.env\.example|\.gitignore|\.cpanel\.yml|\.git">
    Require all denied
</FilesMatch>
<FilesMatch "\.(md|sql)$">
    Require all denied
</FilesMatch>

# In case data/ or includes/ end up inside the webroot on a constrained host
RedirectMatch 404 ^/(data|includes|migrations|scripts)(/|$)
