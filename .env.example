# Go Ultra AI — environment template (per-site config)
# Copy to .env at the repo root. .env is gitignored and never deployed
# automatically. Each site clone keeps its own .env.

APP_ENV=production
APP_URL=https://lpb.cswebserver.in
SITE_NAME="Go Ultra AI"

# Admin
ADMIN_EMAIL=debendra@creatisoul.com
SESSION_LIFETIME_HOURS=8

# Webhook (Phase 5) — leave blank to skip outbound POST; submissions still saved to DB
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=10

# Upload limits (Phase 12)
MAX_IMAGE_BYTES=5242880
MAX_VIDEO_BYTES=52428800

# AI master key (Phase 10) — base64-encoded 32 bytes used to encrypt
# admin-pasted API keys with libsodium secretbox. Generate once with:
#   php -r 'echo base64_encode(random_bytes(32)), "\n";'
# CRITICAL: if this key is lost or rotated, all stored API keys become
# unreadable. There is no recovery — by design. Back it up.
AI_KEYS_MASTER_KEY=

# Default AI provider used by admin AI tools (Phase 11) and the
# frontend chatbot (Phase 13) when a per-tool override isn't set.
# One of: huggingface | gemini | openrouter.
AI_DEFAULT_PROVIDER=huggingface

# Default HuggingFace model when AI_DEFAULT_PROVIDER=huggingface and a
# caller doesn't specify a model. Use any HF Router-routable repo path.
# Verify your subscription has access:
#   curl -H "Authorization: Bearer $HF_KEY" https://router.huggingface.co/v1/models
HF_DEFAULT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Path overrides — only set these if you want core/ or site/ or data/
# outside the repo on a host that allows it. Defaults resolve to the
# repo's own core/ site/ data/ directories.
# CORE_PATH=
# SITE_PATH=
# DATA_PATH=
# DB_PATH=
