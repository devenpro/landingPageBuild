# Go Ultra AI — environment template
# Copy to public_html/.env and fill in. .env is gitignored. Never commit secrets.
# In production this file lives at public_html/.env on the server.

APP_ENV=production
APP_URL=https://lpb.cswebserver.in
SITE_NAME="Go Ultra AI"

# Admin
ADMIN_EMAIL=debendra@creatisoul.com
SESSION_LIFETIME_HOURS=8

# Webhook (Phase 3) — leave blank to skip outbound POST; submissions still saved to DB
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=10

# Upload limits (Phase 6)
MAX_IMAGE_BYTES=5242880
MAX_VIDEO_BYTES=52428800

# Path overrides — only set these if you want data/ or includes/ outside
# the web root on a host that allows it. Defaults resolve to
# public_html/data and public_html/includes.
# DB_PATH=
# INCLUDES_PATH=
# MIGRATIONS_PATH=
