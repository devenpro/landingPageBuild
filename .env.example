# Go Ultra AI — environment template
# Copy to .env and fill in. .env is gitignored. Never commit secrets.

# local | production
APP_ENV=local

# Public-facing URL (no trailing slash)
APP_URL=http://localhost/landingPageBuild/public_html
SITE_NAME="Go Ultra AI"

# Paths — only honored when APP_ENV=production
# When APP_ENV=local, paths are auto-resolved as siblings of public_html/.
DB_PATH=/home/cswebserver/data/content.db
INCLUDES_PATH=/home/cswebserver/includes

# Admin
ADMIN_EMAIL=debendra@creatisoul.com
SESSION_LIFETIME_HOURS=8

# Webhook (Phase 3) — leave blank to skip outbound POST; submissions still saved to DB
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=10

# Upload limits (Phase 6)
MAX_IMAGE_BYTES=5242880
MAX_VIDEO_BYTES=52428800
