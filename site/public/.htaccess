# site/public/.htaccess — doc root for this site.
#
# core/, site/sections/, site/pages/, site/migrations/, data/, .env all
# live OUTSIDE this directory (one or two levels up), so they are not
# directly addressable. This file just enforces HTTPS, sets cache/security
# headers, and is ready for Phase 4's front-controller routing.

DirectoryIndex index.php
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS in production. Skip on localhost so XAMPP dev works on http.
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Phase 14: dynamic XML sitemap. Keeps the canonical /sitemap.xml URL
    # in robots.txt + crawler reports while routing to a PHP handler.
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # Front controller: route any non-existent file/dir to index.php.
    # Phase 4's router uses REQUEST_URI to look up the page slug.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

# Belt-and-braces: deny sensitive file extensions in case any leak in
<FilesMatch "^\.env|\.env\..*|\.gitignore|\.cpanel\.yml|\.git">
    Require all denied
</FilesMatch>
<FilesMatch "\.(md|sql|db|db-journal|db-wal|db-shm)$">
    Require all denied
</FilesMatch>

# Compression. Brotli where the server has it, gzip as fallback. cPanel's
# stock Apache ships both modules on EA4 PHP plans.
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml application/javascript application/json image/svg+xml application/xml application/xml+rss
</IfModule>
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml application/javascript application/json image/svg+xml application/xml application/xml+rss
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    # Compiled CSS and bundled JS — long TTL since site/public/assets/css/styles.css
    # is regenerated by core/build/build-css.sh and re-deployed atomically. If you
    # change a class name without rebuilding, the cached copy lies; that's the
    # tradeoff for 1y cache. Add ?v=N to the <link> tag if you need to force-bust.
    ExpiresByType text/css         "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/svg+xml    "access plus 30 days"
    ExpiresByType image/png        "access plus 30 days"
    ExpiresByType image/jpeg       "access plus 30 days"
    ExpiresByType image/webp       "access plus 30 days"
    ExpiresByType font/woff2       "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "SAMEORIGIN"

    # HSTS: only emit when the request actually came in over HTTPS, so
    # local XAMPP dev (HTTP) doesn't get pinned to HTTPS. 6mo + preload-
    # eligible is the SecurityHeaders.com "A" baseline; bump max-age to
    # 31536000 once you're confident the certificate auto-renews.
    Header always set Strict-Transport-Security "max-age=15768000; includeSubDomains" "expr=%{HTTPS} == 'on'"

    # Match mod_expires with explicit Cache-Control: public, immutable on
    # the long-cacheable asset types. immutable tells the browser not to
    # send conditional requests at all — pure win when the URL is content-
    # addressed or regenerated atomically.
    <FilesMatch "\.(css|js|woff2|svg|png|jpg|jpeg|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
